# Copy to .env.local for local dev. On Vercel, these are auto-injected once you
# attach Neon Postgres in Project → Storage → Create Database → Neon.

# Provided automatically by the Vercel Neon integration. For local dev, paste
# the "DATABASE_URL" value from the Neon connection page.
DATABASE_URL=

# Secret used by the admin API to push tickets. Pick any long random string.
ADMIN_SECRET=change-me-to-a-long-random-string
